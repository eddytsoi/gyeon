# PostgreSQL
DB_USER=gyeon
DB_PASSWORD=change-me-strong-password
DB_NAME=gyeon

# Backend secrets (generate with: openssl rand -hex 32)
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
CUSTOMER_JWT_SECRET=change-me-customer-jwt-secret

# Initial admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Public base URL (set to http://YOUR_GCP_EXTERNAL_IP after VM is created)
BASE_URL=http://YOUR_GCP_EXTERNAL_IP

# MCP storefront server — optional API key to restrict who can connect
# If set, clients must send: Authorization: Bearer <key>  on GET /mcp/sse
# Leave empty to allow all connections (tools are public read/cart/checkout only)
MCP_API_KEY=
